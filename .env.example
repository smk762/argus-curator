# ── argus-curator server ───────────────────────────────────────────────────
# Port for the FastAPI server (default: 8101)
CURATOR_PORT=8101

# CORS for the curator-ui / demo SPA (browser → API). Truthy: 1, true, yes, on.
# ARGUS_CURATOR_CORS=1
# Comma-separated allowlist; leave unset for allow all (*).
# ARGUS_CURATOR_CORS_ORIGINS=https://your-demo.pages.dev,http://localhost:3000

# ── Local directory mounts (used when the SPA runs in local mode) ──────────
# Host paths mounted into the container at /data/images and /data/out.
# Set these to match NEXT_PUBLIC_CURATOR_SOURCE_PATH / NEXT_PUBLIC_CURATOR_OUTPUT_PATH
# in the curator-ui .env (which refer to the container-side paths).
CURATOR_SOURCE_PATH=~/datasets
CURATOR_OUTPUT_PATH=~/curator-out

# ── HuggingFace model cache ────────────────────────────────────────────────
# CLIP and DINOv2 models are downloaded from HuggingFace on first use.
HF_HOME=~/.cache/huggingface

# ── Disable HF telemetry ───────────────────────────────────────────────────
HF_HUB_DISABLE_TELEMETRY=1
